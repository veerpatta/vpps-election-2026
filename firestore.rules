rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function approvedAdmin() {
      return request.auth != null
        && request.auth.token.email == 'raj@vpps.co.in';
    }

    function votingIsOpen() {
      return get(/databases/$(database)/documents/elections/current).data.status == 'voting_open';
    }

    match /elections/{electionId} {
      allow read: if true;
      allow write: if approvedAdmin();
    }

    match /candidates/{candidateId} {
      allow read: if true;
      allow write: if approvedAdmin();
    }

    match /voters/{voterId} {
      // Public voter lookup is needed for the 6-digit Voting ID flow.
      // Admin management remains restricted to the approved Google account.
      allow read: if true;
      allow create, delete: if approvedAdmin();
      allow update: if approvedAdmin()
        || (
          votingIsOpen()
          && resource.data.active == true
          && resource.data.hasVoted == false
          && request.resource.data.hasVoted == true
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['hasVoted', 'votedAt'])
        );
    }

    match /votes/{voteId} {
      // Vote records intentionally contain no voter name, Voting ID, or voter id.
      allow read, update, delete: if approvedAdmin();
      allow create: if votingIsOpen()
        && request.resource.data.keys().hasOnly(['id', 'electionId', 'postId', 'candidateId', 'createdAt'])
        && !('voterName' in request.resource.data)
        && !('votingId' in request.resource.data)
        && !('voterId' in request.resource.data);
    }

    match /adminUsers/{adminUserId} {
      allow read, write: if approvedAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
