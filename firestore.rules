rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function approvedAdmin() {
      return request.auth != null
        && request.auth.token.email == 'raj@vpps.co.in';
    }

    // Admin screens require Firebase Google Sign-In and the app also restricts
    // access to raj@vpps.co.in. These rules mirror that allowlist for future
    // Firestore-backed admin tools.
    match /elections/{electionId} {
      allow read, write: if approvedAdmin();
    }

    match /candidates/{candidateId} {
      allow read, write: if approvedAdmin();
    }

    match /voters/{voterId} {
      allow read, write: if approvedAdmin();
    }

    match /votes/{voteId} {
      allow read, write: if approvedAdmin();
    }

    match /adminUsers/{adminUserId} {
      allow read, write: if approvedAdmin();
    }

    // The voter flow still uses app-level 6-digit Voting ID logic in localStorage.
    // Do not add public vote writes until final live vote-write rules are tested
    // before election day.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
